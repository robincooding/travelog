generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int                   @id @default(autoincrement())
  email        String                @unique
  passwordHash String                                // bcrypt hash (평문 비밀번호 절대 저장 X)
  displayName  String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  collections  Collection[]
  resetTokens  PasswordResetToken[]
}

/**
 * 비밀번호 재설정 토큰.
 * - tokenHash 만 저장 (DB 가 유출돼도 토큰을 그대로 쓸 수 없도록 — 비밀번호 해싱과 같은 원칙)
 * - 단일 사용 (usedAt 으로 표시) + 만료 (expiresAt) + 감사 추적용 createdAt
 */
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique   // SHA-256 (토큰 자체가 64자 hex 고엔트로피라 bcrypt 불필요)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Collection {
  id          Int       @id @default(autoincrement())
  userId      Int?                                  // Step 5 시드 후 NOT NULL 로 강화 예정
  title       String
  theme       String
  description String?
  coverImage  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  places      Place[]
  profile     CollectionProfile?

  @@index([userId])
}

model Place {
  id             Int        @id @default(autoincrement())
  collectionId   Int
  name           String
  googlePlaceId  String?
  address        String?
  city           String?
  country        String?
  lat            Float
  lng            Float
  category       String?
  curatorNote    String?   // 왜 좋았는지
  highlight      String?   // 가장 기억에 남는 것
  feeling        String?   // 그 순간의 감정
  mood           String?
  visitedAt      DateTime
  travelContext  String?
  photos         String     @default("[]")
  createdAt      DateTime   @default(now())

  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model CollectionProfile {
  id              Int        @id @default(autoincrement())
  collectionId    Int        @unique
  themeType       String?    // AI 분석 결과 — 감성형 / 탐험형 / 미식형 등
  summary         String?
  recommendations String?    // JSON array
  generatedAt     DateTime   @default(now())

  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}