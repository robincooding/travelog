generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Collection {
  id          Int       @id @default(autoincrement())
  title       String
  theme       String
  description String?
  coverImage  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  places      Place[]
  orders      Order[]
  profile     CollectionProfile?
}

model Place {
  id             Int        @id @default(autoincrement())
  collectionId   Int
  name           String
  googlePlaceId  String?
  address        String?
  city           String?
  country        String?
  lat            Float
  lng            Float
  category       String?
  curatorNote    String?
  mood           String?
  visitedAt      DateTime
  travelContext  String?
  photos         String     @default("[]")
  createdAt      DateTime   @default(now())

  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model Order {
  id           Int        @id @default(autoincrement())
  collectionId Int
  bookTitle    String
  size         String     @default("A5")
  pageCount    Int?
  status       String     @default("pending")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model CollectionProfile {
  id              Int        @id @default(autoincrement())
  collectionId    Int        @unique
  themeType       String?    // AI 분석 결과 — 감성형 / 탐험형 / 미식형 등
  summary         String?
  recommendations String?    // JSON array
  generatedAt     DateTime   @default(now())

  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}