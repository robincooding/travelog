generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String                       // bcrypt hash (평문 비밀번호 절대 저장 X)
  displayName  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  collections  Collection[]
}

model Collection {
  id          Int       @id @default(autoincrement())
  userId      Int?                                  // Step 5 시드 후 NOT NULL 로 강화 예정
  title       String
  theme       String
  description String?
  coverImage  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  places      Place[]
  profile     CollectionProfile?

  @@index([userId])
}

model Place {
  id             Int        @id @default(autoincrement())
  collectionId   Int
  name           String
  googlePlaceId  String?
  address        String?
  city           String?
  country        String?
  lat            Float
  lng            Float
  category       String?
  curatorNote    String?   // 왜 좋았는지
  highlight      String?   // 가장 기억에 남는 것
  feeling        String?   // 그 순간의 감정
  mood           String?
  visitedAt      DateTime
  travelContext  String?
  photos         String     @default("[]")
  createdAt      DateTime   @default(now())

  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model CollectionProfile {
  id              Int        @id @default(autoincrement())
  collectionId    Int        @unique
  themeType       String?    // AI 분석 결과 — 감성형 / 탐험형 / 미식형 등
  summary         String?
  recommendations String?    // JSON array
  generatedAt     DateTime   @default(now())

  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}