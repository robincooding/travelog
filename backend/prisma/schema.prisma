generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url 은 prisma.config.ts 의 datasource.url 에서 관리 (Prisma 7 새 권장 방식)
}

model User {
  id           Int                   @id @default(autoincrement())
  email        String                @unique
  passwordHash String                                // bcrypt hash (평문 비밀번호 절대 저장 X)
  displayName  String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  collections  Collection[]
  resetTokens  PasswordResetToken[]
  aiUsage      AiUsageDaily[]
  wishlist     WishlistItem[]
}

/**
 * 비밀번호 재설정 토큰.
 * - tokenHash 만 저장 (DB 가 유출돼도 토큰을 그대로 쓸 수 없도록 — 비밀번호 해싱과 같은 원칙)
 * - 단일 사용 (usedAt 으로 표시) + 만료 (expiresAt) + 감사 추적용 createdAt
 */
/**
 * 사용자별 AI 호출 카운터 (일자 단위 집계).
 * - row 한 개로 하루치 사용량 표현 → 매 호출마다 row 추가하는 방식보다 효율적
 * - 일자 비교는 YYYY-MM-DD 문자열로 단순화 (timezone 혼란 회피, 서버 로컬 일자 기준)
 * - 과거 데이터는 추후 cleanup job 으로 일괄 삭제 가능
 */
model AiUsageDaily {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      String                   // YYYY-MM-DD
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique   // SHA-256 (토큰 자체가 64자 hex 고엔트로피라 bcrypt 불필요)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Collection {
  id          Int       @id @default(autoincrement())
  userId      Int?                                  // Step 5 시드 후 NOT NULL 로 강화 예정
  title       String
  theme       String
  description String?
  coverImage  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  places      Place[]
  profile     CollectionProfile?
  wishItems   WishlistItem[]

  @@index([userId])
}

/**
 * 위시리스트 — "가보고 싶은 곳" 모음.
 * AI 추천 chip 을 클릭해 추가하거나, 사용자가 직접 입력 가능.
 * - (userId, name) unique 로 중복 추가 방지
 * - sourceCollection 은 추천이 어느 컬렉션 분석에서 왔는지 추적 (nullable)
 *   원본 컬렉션이 삭제되어도 위시는 살아남음 → onDelete: SetNull
 */
model WishlistItem {
  id                 Int      @id @default(autoincrement())
  userId             Int
  name               String
  city               String?
  country            String?
  sourceCollectionId Int?
  createdAt          DateTime @default(now())

  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceCollection Collection? @relation(fields: [sourceCollectionId], references: [id], onDelete: SetNull)

  @@unique([userId, name])
  @@index([userId])
}

model Place {
  id             Int        @id @default(autoincrement())
  collectionId   Int
  name           String
  googlePlaceId  String?
  address        String?
  city           String?
  country        String?
  lat            Float
  lng            Float
  category       String?
  curatorNote    String?   // 왜 좋았는지
  highlight      String?   // 가장 기억에 남는 것
  feeling        String?   // 그 순간의 감정
  mood           String?
  visitedAt      DateTime
  travelContext  String?
  photos         String     @default("[]")
  createdAt      DateTime   @default(now())

  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model CollectionProfile {
  id              Int        @id @default(autoincrement())
  collectionId    Int        @unique
  themeType       String?    // AI 분석 결과 — 감성형 / 탐험형 / 미식형 등
  summary         String?
  recommendations String?    // JSON array
  generatedAt     DateTime   @default(now())

  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}