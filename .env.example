# PostgreSQL 연결 — 도커 컴포즈에선 host 가 postgres 서비스명, 로컬 개발은 localhost
# 예: postgresql://loci:loci@localhost:5432/loci  (로컬에서 backend 만 직접 띄울 때)
DATABASE_URL=postgresql://loci:loci@postgres:5432/loci

# PostgreSQL 컨테이너 자격 증명 (운영 환경에선 강한 비밀번호 + secret manager 사용)
# POSTGRES_PORT 는 호스트 매핑 포트 — 컨테이너 내부 통신은 5432 로 그대로
POSTGRES_USER=loci
POSTGRES_PASSWORD=loci
POSTGRES_DB=loci
POSTGRES_PORT=5432

GEMINI_API_KEY=
BACKEND_PORT=3000
FRONTEND_PORT=8080
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=

# JWT 서명에 쓰는 비밀키 — openssl rand -hex 64 같은 명령으로 충분히 긴 랜덤값을 사용하세요
JWT_SECRET=

# CORS 화이트리스트 — 쉼표로 구분, 정확히 일치하는 origin 만 허용
# 빈 값이면 기본값 (http://localhost:5173, http://localhost:8080) 사용
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# 프론트엔드 base URL — forgot-password 이메일 링크 생성에 사용
FRONTEND_URL=http://localhost:5173